# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3012
API_PREFIX=api
APP_NAME=EventHub360-FIN

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eventhub360_fin?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── JWT (issued by the central Auth Service) ─────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=refresh-change-me
JWT_REFRESH_EXPIRES_IN=30d

# ── Redis (cache + Bull queues) ──────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=fin:

# ── MinIO (S3-compatible object storage) ─────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_BUCKET_INVOICES=fin-invoices
MINIO_BUCKET_RECEIPTS=fin-receipts
MINIO_BUCKET_BILLS=fin-vendor-bills
MINIO_BUCKET_EXPENSES=fin-expenses
MINIO_BUCKET_REPORTS=fin-reports

# ── Company (supplier) GST identity ──────────────────────────
COMPANY_GSTIN=27AABCU9603R1ZX
COMPANY_STATE=Maharashtra
COMPANY_STATE_CODE=27

# ── Finance jobs & rules ─────────────────────────────────────
DUNNING_CRON_SCHEDULE=0 18 30 * * *
GST_PREPARE_CRON=0 0 1 * *
RECONCILIATION_ALERT_DAYS=30
EXPENSE_OCR_TOLERANCE=0.02
MAX_FILE_SIZE_MB=10

# ── SMTP (invoice / dunning emails) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="EventHub360 Finance <noreply@eventhub360.com>"

# ── Rate limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Swagger ──────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
